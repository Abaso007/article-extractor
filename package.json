{
  "version": "8.1.0",
  "name": "@extractus/article-extractor",
  "description": "To extract main article from given URL",
  "homepage": "https://github.com/extractus/article-extractor",
  "repository": {
    "type": "git",
    "url": "git@github.com:extractus/article-extractor.git"
  },
  "author": "@extractus",
  "main": "./src/main.js",
  "type": "module",
  "exports": {
