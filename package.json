    "linkedom": "^0.18.12",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "https-proxy-agent": "^9.0.0",
    "nock": "^14.0.14"
  },
  "files": [
    "src",
    "index.d.ts"
  ],
